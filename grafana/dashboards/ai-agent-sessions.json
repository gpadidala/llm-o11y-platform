{
  "uid": "ai-agent-sessions",
  "title": "AI Agent & MCP Sessions",
  "description": "Agent and MCP tool call intelligence: session analytics, tool performance, cost attribution, and server health.",
  "tags": ["llm", "mcp", "agent", "sessions", "advanced"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {},
  "links": [
    {
      "title": "AI Reliability Engineering",
      "type": "link",
      "url": "/d/ai-reliability/ai-reliability-engineering",
      "icon": "heart",
      "tooltip": "SLI/SLO tracking and reliability engineering",
      "targetBlank": false
    },
    {
      "title": "AI Cost Intelligence",
      "type": "link",
      "url": "/d/ai-cost-intel/ai-cost-intelligence",
      "icon": "bolt",
      "tooltip": "Deep cost analysis and forecasting",
      "targetBlank": false
    },
    {
      "title": "AI Model Comparison",
      "type": "link",
      "url": "/d/ai-model-compare/ai-model-comparison",
      "icon": "exchange-alt",
      "tooltip": "Side-by-side model benchmarking",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "server_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(mcp_tool_calls_total, server_name)",
        "query": {
          "query": "label_values(mcp_tool_calls_total, server_name)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "tool_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(mcp_tool_calls_total{server_name=~\"$server_name\"}, tool_name)",
        "query": {
          "query": "label_values(mcp_tool_calls_total{server_name=~\"$server_name\"}, tool_name)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "agent_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(mcp_session_cost_usd_total, agent_name)",
        "query": {
          "query": "label_values(mcp_session_cost_usd_total, agent_name)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Agent Overview",
      "id": 100,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 101,
      "title": "Active Sessions",
      "description": "Count of unique active sessions currently in progress, based on distinct session_id labels observed in the selected time range.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(count by (session_id) (mcp_session_cost_usd_total{agent_name=~\"$agent_name\"}))",
          "legendFormat": "Active Sessions",
          "instant": true
        }
      ]
    },
    {
      "id": 102,
      "title": "Total Tool Calls",
      "description": "Total number of MCP tool calls across all servers and tools in the selected time range.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 100 },
              { "color": "yellow", "value": 10000 },
              { "color": "orange", "value": 100000 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(mcp_tool_calls_total{server_name=~\"$server_name\", tool_name=~\"$tool_name\"}[$__range]))",
          "legendFormat": "Total Tool Calls",
          "instant": true
        }
      ]
    },
    {
      "id": 103,
      "title": "Session Cost",
      "description": "Total accumulated cost across all MCP sessions for the selected agents and time range.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "currencyUSD",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(mcp_session_cost_usd_total{agent_name=~\"$agent_name\"}[$__range]))",
          "legendFormat": "Total Session Cost",
          "instant": true
        }
      ]
    },
    {
      "id": 104,
      "title": "Avg Tools per Session",
      "description": "Average number of tool calls per session, indicating typical agent workflow complexity.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 3 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          },
          "unit": "short",
          "decimals": 1,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(mcp_tool_calls_total{server_name=~\"$server_name\", tool_name=~\"$tool_name\"}[$__range]))\n/\nclamp_min(count(count by (session_id) (mcp_session_cost_usd_total{agent_name=~\"$agent_name\"})), 1)",
          "legendFormat": "Avg Tools/Session",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "Tool Analytics",
      "id": 105,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 106,
      "title": "Tool Call Rate by Tool",
      "description": "Stacked timeseries showing the rate of tool calls broken down by individual tool, revealing which tools are most active.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "calls/s",
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (tool_name) (rate(mcp_tool_calls_total{server_name=~\"$server_name\", tool_name=~\"$tool_name\"}[$__rate_interval]))",
          "legendFormat": "{{tool_name}}"
        }
      ]
    },
    {
      "id": 107,
      "title": "Tool Latency by Tool (P50 / P95)",
      "description": "Grouped bar chart comparing P50 and P95 latency for each MCP tool. Identifies slow tools that may bottleneck agent workflows.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*P50.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*P95.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (tool_name, le) (rate(mcp_tool_duration_milliseconds_bucket{server_name=~\"$server_name\", tool_name=~\"$tool_name\"}[$__rate_interval])))",
          "legendFormat": "{{tool_name}} P50",
          "instant": true,
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (tool_name, le) (rate(mcp_tool_duration_milliseconds_bucket{server_name=~\"$server_name\", tool_name=~\"$tool_name\"}[$__rate_interval])))",
          "legendFormat": "{{tool_name}} P95",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 108,
      "title": "Tool Success Rate",
      "description": "Success rate per tool as a bar chart. Tools with rates below 95% may need attention.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (\n  sum by (tool_name) (increase(mcp_tool_calls_total{server_name=~\"$server_name\", tool_name=~\"$tool_name\", status=\"success\"}[$__range]))\n  /\n  clamp_min(sum by (tool_name) (increase(mcp_tool_calls_total{server_name=~\"$server_name\", tool_name=~\"$tool_name\"}[$__range])), 1)\n)",
          "legendFormat": "{{tool_name}}",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 109,
      "title": "Tool Cost Attribution",
      "description": "Pie chart showing estimated cost attribution by tool, based on the proportion of tool calls weighted by session cost.",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "displayLabels": ["percent"]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (tool_name) (increase(mcp_tool_calls_total{server_name=~\"$server_name\", tool_name=~\"$tool_name\"}[$__range]))",
          "legendFormat": "{{tool_name}}",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "Session Analysis",
      "id": 110,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 111,
      "title": "Session Duration Distribution",
      "description": "Histogram of MCP tool call durations, providing insight into session duration patterns and identifying outliers.",
      "type": "histogram",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        },
        "overrides": []
      },
      "options": {
        "bucketSize": 500,
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (le) (increase(mcp_tool_duration_milliseconds_bucket{server_name=~\"$server_name\", tool_name=~\"$tool_name\"}[$__range]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 112,
      "title": "Session Cost Distribution",
      "description": "Distribution of costs across sessions, revealing whether cost is evenly distributed or concentrated in a few expensive sessions.",
      "type": "histogram",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD",
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        },
        "overrides": []
      },
      "options": {
        "bucketSize": 1,
        "combine": true,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (session_id) (increase(mcp_session_cost_usd_total{agent_name=~\"$agent_name\"}[$__range]))",
          "legendFormat": "{{session_id}}",
          "instant": true
        }
      ]
    },
    {
      "id": 113,
      "title": "Top Sessions by Cost",
      "description": "Table showing the most expensive sessions sorted by cost descending, with session ID, agent name, and total cost.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Cost ($)" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "session_id" },
            "properties": [
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Cost ($)", "desc": true }],
        "cellHeight": "sm",
        "footer": { "show": true, "reducer": ["sum"], "countRows": false, "enablePagination": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(20, sum by (session_id, agent_name) (increase(mcp_session_cost_usd_total{agent_name=~\"$agent_name\"}[$__range])))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "Value": "Cost ($)" }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [{ "field": "Cost ($)", "desc": true }]
          }
        }
      ]
    },
    {
      "id": 114,
      "title": "Session Timeline",
      "description": "State timeline showing tool call activity per server over time. Each state represents the tool being invoked on that server.",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 0.001,
                "result": { "text": "Idle", "color": "transparent", "index": 0 }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.001,
                "to": 1000000,
                "result": { "text": "Active", "color": "green", "index": 1 }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "rowHeight": 0.8,
        "mergeValues": true,
        "alignValue": "left",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (server_name, tool_name) (rate(mcp_tool_calls_total{server_name=~\"$server_name\", tool_name=~\"$tool_name\"}[$__rate_interval]))",
          "legendFormat": "{{server_name}}/{{tool_name}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "MCP Server Health",
      "id": 115,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 116,
      "title": "Server Call Rate",
      "description": "Rate of tool calls per MCP server over time, showing server load and utilization patterns.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "calls/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
