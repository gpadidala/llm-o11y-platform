{
  "uid": "llm-qos",
  "title": "LLM O11y — Quality of Service",
  "description": "Quality of Service dashboard: SLA tracking, reliability metrics, capacity planning, and cost control for LLM operations.",
  "tags": ["llm", "observability", "qos", "sla"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "provider",
        "type": "query",
        "label": "Provider",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(llm_requests_total, provider)",
        "query": {
          "query": "label_values(llm_requests_total, provider)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "model",
        "type": "query",
        "label": "Model",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(llm_requests_total{provider=~\"$provider\"}, model)",
        "query": {
          "query": "label_values(llm_requests_total{provider=~\"$provider\"}, model)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "SLA Tracking",
      "id": 1,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Latency SLA Compliance (< 2s)",
      "description": "Percentage of requests completing within 2000ms SLA threshold, with 99.9% target line.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "percent",
          "min": 90,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "min"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (1 - clamp_min(histogram_quantile(1.0, sum by (le) (rate(llm_request_duration_milliseconds_bucket{provider=~\"$provider\", model=~\"$model\", le=\"2000\"}[$__rate_interval]))) / clamp_min(sum(rate(llm_request_duration_milliseconds_count{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 0.001), 0))",
          "legendFormat": "< 2s Compliance",
          "hide": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(llm_request_duration_milliseconds_bucket{provider=~\"$provider\", model=~\"$model\", le=\"2000\"}[$__rate_interval])) / clamp_min(sum(rate(llm_request_duration_milliseconds_count{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 0.001)",
          "legendFormat": "% Requests < 2s"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Budget Remaining",
      "description": "Error budget remaining: 100% minus current error rate. Burns down as errors accumulate.",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "yellow", "value": 75 },
              { "color": "green", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (100 * sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status=\"error\"}[$__rate_interval])) / clamp_min(sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 1))",
          "legendFormat": "Error Budget"
        }
      ]
    },
    {
      "id": 4,
      "title": "TTFT SLA Compliance (< 500ms)",
      "description": "Percentage of requests with Time to First Token under 500ms.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "percent",
          "min": 90,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "min"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(llm_ttft_milliseconds_bucket{provider=~\"$provider\", model=~\"$model\", le=\"500\"}[$__rate_interval])) / clamp_min(sum(rate(llm_ttft_milliseconds_count{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 0.001)",
          "legendFormat": "% TTFT < 500ms"
        }
      ]
    },
    {
      "type": "row",
      "title": "Reliability",
      "id": 10,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "title": "Error Rate Heatmap (by Hour)",
      "description": "Error rate distribution visualized as a heatmap across time.",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "calculate": true,
        "calculation": { "xBuckets": { "mode": "size", "value": "1h" } },
        "color": {
          "mode": "scheme",
          "scheme": "RdYlGn",
          "reverse": true,
          "fill": "dark-orange",
          "exponent": 0.5
        },
        "cellGap": 2,
        "yAxis": { "unit": "percent" },
        "tooltip": { "show": true, "yHistogram": false },
        "legend": { "show": true }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status=\"error\"}[5m])) / clamp_min(sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[5m])), 1)",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "id": 12,
      "title": "Error Distribution by Status",
      "description": "Distribution of errors across different status types.",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "right", "values": ["percent", "value"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (status) (increase(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status!=\"success\"}[$__range]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Mean Time Between Failures",
      "description": "Estimated mean time between error occurrences.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 600 }
            ]
          },
          "unit": "s",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1 / clamp_min(sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status=\"error\"}[$__rate_interval])), 0.0001)",
          "legendFormat": "MTBF"
        }
      ]
    },
    {
      "id": 14,
      "title": "Consecutive Success Count",
      "description": "Approximate count of consecutive successful requests since last error.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 100 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status=\"success\"}[$__rate_interval])) / clamp_min(sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status=\"error\"}[$__rate_interval])), 0.0001)",
          "legendFormat": "Success:Error Ratio"
        }
      ]
    },
    {
      "id": 15,
      "title": "Error Rate Over Time",
      "description": "Error rate percentage tracked over time.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "hidden", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status=\"error\"}[$__rate_interval])) / clamp_min(sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 1)",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "type": "row",
      "title": "Capacity",
      "id": 20,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "title": "Request Rate vs Capacity",
      "description": "Current request rate with a reference threshold line indicating estimated max capacity.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "Request Rate"
        }
      ]
    },
    {
      "id": 22,
      "title": "Token Throughput Trend",
      "description": "Token processing rate over time with linear regression trend.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "tokens/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (token_type) (rate(llm_tokens_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "{{token_type}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_tokens_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 23,
      "title": "Provider Utilization",
      "description": "Request share per provider as percentage of total traffic.",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlYlRd" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum by (provider) (rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])) / clamp_min(sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{provider}}",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "Cost Control",
      "id": 30,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "title": "Cost Anomaly Detection",
      "description": "Actual cost rate vs expected (moving average) with standard deviation bands to detect anomalies.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "$/hr",
            "drawStyle": "line",
            "fillOpacity": 0,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "currencyUSD"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Actual" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Expected (Avg)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Upper Band" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [4, 4] } },
              { "id": "custom.fillOpacity", "value": 5 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Lower Band" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [4, 4] } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])) * 3600",
          "legendFormat": "Actual"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg_over_time(sum(rate(llm_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[5m]))[1h:5m]) * 3600",
          "legendFormat": "Expected (Avg)"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(avg_over_time(sum(rate(llm_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[5m]))[1h:5m]) + 2 * stddev_over_time(sum(rate(llm_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[5m]))[1h:5m])) * 3600",
          "legendFormat": "Upper Band"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "clamp_min((avg_over_time(sum(rate(llm_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[5m]))[1h:5m]) - 2 * stddev_over_time(sum(rate(llm_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[5m]))[1h:5m])) * 3600, 0)",
          "legendFormat": "Lower Band"
        }
      ]
    },
    {
      "id": 32,
      "title": "Budget Consumption",
