    {
      "id": 119,
      "title": "Model Ranking Table",
      "description": "Comprehensive model comparison table with sortable columns for latency (P50/P95), cost per request, error rate, and throughput. Use column headers to sort and compare.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P50 Latency (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1000 },
                    { "color": "red", "value": 3000 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Error Rate (%)" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 2 },
                    { "color": "red", "value": 5 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Cost/Req ($)" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Throughput (tok/s)" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 1 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Cost/Req ($)", "desc": false }],
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"], "countRows": false, "enablePagination": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (model, le) (rate(llm_request_duration_milliseconds_bucket{model=~\"$models\"}[$__rate_interval])))",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (increase(llm_cost_usd_total{model=~\"$models\"}[$__range])) / clamp_min(sum by (model) (increase(llm_requests_total{model=~\"$models\"}[$__range])), 1)",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum by (model) (increase(llm_requests_total{model=~\"$models\", status=\"error\"}[$__range])) / clamp_min(sum by (model) (increase(llm_requests_total{model=~\"$models\"}[$__range])), 1)",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (rate(llm_tokens_total{model=~\"$models\", token_type=\"completion\"}[$__rate_interval]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "model" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true },
            "renameByName": {
              "model": "Model",
              "Value #A": "P50 Latency (ms)",
              "Value #B": "Cost/Req ($)",
              "Value #C": "Error Rate (%)",
              "Value #D": "Throughput (tok/s)"
            }
          }
        }
      ]
    }
