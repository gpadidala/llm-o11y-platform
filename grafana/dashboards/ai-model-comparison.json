        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (increase(llm_tokens_total{model=~\"$models\", token_type=\"completion\"}[$__range]))",
          "legendFormat": "{{model}} (completion)",
