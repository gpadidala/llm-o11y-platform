      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg_over_time(sum by (model) (rate(llm_requests_total{model=~\"$models\"}[5m]))[7d:1h])",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Quality Indicators",
      "id": 115,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 116,
      "title": "Success Rate by Model",
      "description": "Percentage of successful requests for each model. Higher is better. Models below 95% may need investigation.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
