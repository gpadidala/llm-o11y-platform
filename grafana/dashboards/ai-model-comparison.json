      "collapsed": false,
      "panels": []
    },
    {
      "id": 111,
      "title": "Request Distribution",
      "description": "Pie chart showing the percentage of total requests handled by each model.",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "displayLabels": ["percent"]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (increase(llm_requests_total{model=~\"$models\"}[$__range]))",
          "legendFormat": "{{model}}",
          "instant": true
        }
      ]
    },
