{
  "uid": "ai-model-compare",
  "title": "AI Model Comparison",
  "description": "Side-by-side model benchmarking across performance, cost, usage patterns, and quality indicators.",
  "tags": ["llm", "model", "comparison", "advanced"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "links": [
    {
      "title": "AI Reliability Engineering",
      "type": "link",
      "url": "/d/ai-reliability/ai-reliability-engineering",
      "icon": "heart",
      "tooltip": "SLI/SLO tracking and reliability engineering",
      "targetBlank": false
    },
    {
      "title": "AI Cost Intelligence",
      "type": "link",
      "url": "/d/ai-cost-intel/ai-cost-intelligence",
      "icon": "bolt",
      "tooltip": "Deep cost analysis and forecasting",
      "targetBlank": false
    },
    {
      "title": "AI Agent & MCP Sessions",
      "type": "link",
      "url": "/d/ai-agent-sessions/ai-agent-mcp-sessions",
      "icon": "users-alt",
      "tooltip": "Agent and MCP tool call intelligence",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "models",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(llm_requests_total, model)",
        "query": {
          "query": "label_values(llm_requests_total, model)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Performance Matrix",
      "id": 100,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 101,
      "title": "Latency Comparison (P50 / P95 / P99)",
      "description": "Grouped bar chart comparing P50, P95, and P99 latency across all selected models. Lower is better.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*P50.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*P95.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*P99.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (model, le) (rate(llm_request_duration_milliseconds_bucket{model=~\"$models\"}[$__rate_interval])))",
          "legendFormat": "{{model}} P50",
          "instant": true,
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(llm_request_duration_milliseconds_bucket{model=~\"$models\"}[$__rate_interval])))",
          "legendFormat": "{{model}} P95",
          "instant": true,
          "format": "time_series"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (model, le) (rate(llm_request_duration_milliseconds_bucket{model=~\"$models\"}[$__rate_interval])))",
          "legendFormat": "{{model}} P99",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 102,
      "title": "TTFT Comparison (P50 / P95)",
      "description": "Grouped bar chart comparing Time to First Token at P50 and P95 percentiles per model. Critical for streaming response quality.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*P50.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*P95.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }
            ]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (model, le) (rate(llm_ttft_milliseconds_bucket{model=~\"$models\"}[$__rate_interval])))",
          "legendFormat": "{{model}} P50",
          "instant": true,
          "format": "time_series"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(llm_ttft_milliseconds_bucket{model=~\"$models\"}[$__rate_interval])))",
          "legendFormat": "{{model}} P95",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 103,
      "title": "Throughput Comparison (Tokens/sec)",
      "description": "Bar chart comparing token generation throughput per model. Calculated as total tokens generated per second. Higher is better.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "axisLabel": "tokens/sec"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (rate(llm_tokens_total{model=~\"$models\", token_type=\"completion\"}[$__rate_interval]))",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 104,
      "title": "Error Rate Comparison",
      "description": "Error rate percentage per model. A red threshold line at 5% indicates the acceptable error boundary.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (\n  sum by (model) (increase(llm_requests_total{model=~\"$models\", status=\"error\"}[$__range]))\n  /\n  clamp_min(sum by (model) (increase(llm_requests_total{model=~\"$models\"}[$__range])), 1)\n)",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "type": "row",
      "title": "Cost Matrix",
      "id": 105,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 106,
      "title": "Cost per 1K Tokens by Model",
      "description": "Horizontal bar chart comparing cost per 1,000 tokens for each model. Lower is more cost-effective.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(\n  sum by (model) (increase(llm_cost_usd_total{model=~\"$models\"}[$__range]))\n  /\n  clamp_min(sum by (model) (increase(llm_tokens_total{model=~\"$models\"}[$__range])), 1)\n) * 1000",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 107,
      "title": "Cost per Request by Model",
      "description": "Horizontal bar chart comparing the average cost per request for each model.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (increase(llm_cost_usd_total{model=~\"$models\"}[$__range]))\n/\nclamp_min(sum by (model) (increase(llm_requests_total{model=~\"$models\"}[$__range])), 1)",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 108,
      "title": "Token Efficiency by Model",
      "description": "Output/input token ratio per model. Higher values indicate more content generated per input token, suggesting better prompt efficiency.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "decimals": 2,
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "axisLabel": "output/input ratio"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (increase(llm_tokens_total{model=~\"$models\", token_type=\"completion\"}[$__range]))\n/\nclamp_min(sum by (model) (increase(llm_tokens_total{model=~\"$models\", token_type=\"prompt\"}[$__range])), 1)",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "id": 109,
      "title": "Value Score (Throughput / Cost)",
      "description": "Custom value metric: tokens per second divided by cost per token. Higher scores indicate better value (more output per dollar). Useful for model selection decisions.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "decimals": 1,
          "custom": {
            "axisBorderShow": false,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "axisLabel": "value score"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(\n  sum by (model) (rate(llm_tokens_total{model=~\"$models\", token_type=\"completion\"}[$__rate_interval]))\n)\n/\nclamp_min(\n  sum by (model) (rate(llm_cost_usd_total{model=~\"$models\"}[$__rate_interval])),\n  0.0001\n)",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "time_series"
        }
      ]
    },
    {
      "type": "row",
      "title": "Usage Patterns",
