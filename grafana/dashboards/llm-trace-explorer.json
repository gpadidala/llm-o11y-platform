{
  "uid": "llm-trace-explorer",
  "title": "LLM O11y — Trace Explorer",
  "description": "Explore distributed traces for LLM requests, view span details, and analyze latency distributions.",
  "tags": ["llm", "traces", "tempo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(traces_spanmetrics_calls_total, service)",
        "query": {
          "query": "label_values(traces_spanmetrics_calls_total, service)",
          "refId": "StandardVariableQuery"
        },
        "multi": false,
        "includeAll": true,
        "allValue": "",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "minDuration",
        "type": "textbox",
        "current": { "selected": false, "text": "", "value": "" },
        "label": "Min Duration",
        "description": "Minimum span duration filter (e.g. 100ms, 1s)"
      },
      {
        "name": "traceId",
        "type": "textbox",
        "current": { "selected": false, "text": "", "value": "" },
        "label": "Trace ID",
        "description": "Look up a specific trace by ID"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Trace Search",
      "description": "Search for traces by service, duration, and tags.",
      "type": "traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "serviceName": "$service",
          "minDuration": "$minDuration",
          "limit": 20,
          "filters": [
            {
              "id": "service-name",
              "scope": "resource",
              "tag": "service.name",
              "operator": "=",
              "value": ["$service"]
            },
            {
              "id": "min-duration",
              "scope": "span",
              "tag": "duration",
              "operator": ">",
              "value": ["$minDuration"]
            }
          ]
        }
      ]
    },
    {
      "id": 2,
      "title": "Trace Detail",
      "description": "View the full trace timeline and span breakdown for a selected trace.",
      "type": "traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 12 },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "$traceId",
          "limit": 20
        }
      ]
    },
    {
      "id": 3,
      "title": "Recent Traces",
      "description": "Table of recent traces showing service, duration, and span count.",
      "type": "table",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "filterable": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View Trace",
                    "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"datasource\":{\"type\":\"tempo\",\"uid\":\"tempo\"},\"queryType\":\"traceql\",\"query\":\"${__value.raw}\"}],\"range\":{\"from\":\"now-1h\",\"to\":\"now\"}}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "traceDuration" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "displayName", "value": "Duration" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Duration" }],
        "footer": { "enablePagination": true }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "limit": 50,
          "tableType": "traces",
          "filters": [
            {
              "id": "service-name",
              "scope": "resource",
              "tag": "service.name",
              "operator": "=",
              "value": ["$service"]
            }
          ]
        }
      ]
    },
    {
      "id": 4,
      "title": "Span Duration Distribution",
      "description": "Distribution of span durations as a histogram to identify latency patterns and outliers.",
      "type": "histogram",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "bucketSize": "",
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (le) (increase(llm_request_duration_bucket{provider=~\".*\"}[$__range]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [
    {
      "title": "Overview",
      "type": "link",
      "icon": "external link",
      "url": "/d/llm-overview/llm-o11y-overview",
      "targetBlank": false
    },
    {
      "title": "Cost & Token Analysis",
      "type": "link",
      "icon": "external link",
      "url": "/d/llm-cost-tokens/llm-o11y-cost-token-analysis",
      "targetBlank": false
    }
  ]
}
