          "expr": "sum by (provider) (rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status=\"error\"}[$__rate_interval]))\n/\nsum by (provider) (rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "{{provider}}"
