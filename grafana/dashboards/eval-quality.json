{
  "uid": "eval-quality",
  "title": "Evaluation & Quality Scores",
  "description": "LLM output evaluation scores, quality trends, judge latency, and criterion-level analytics",
  "tags": ["llm-o11y", "evaluation", "quality"],
  "editable": true,
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "1m",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Eval Runs Count",
      "description": "Total number of evaluation runs in the selected time range",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(eval_runs_total[24h]))",
          "legendFormat": "Eval Runs"
        }
      ]
    },
    {
      "id": 2,
      "title": "Average Score by Criterion",
      "description": "Mean evaluation score for each quality criterion",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Score",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" },
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (criterion) (eval_score_sum / eval_score_count)",
          "legendFormat": "{{criterion}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Score Distribution Histogram",
      "description": "Distribution of evaluation scores across all criteria",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" },
        "bucketSize": 0.1,
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "bucketOffset": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (eval_score_bucket)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 4,
      "title": "Score Trend Over Time",
      "description": "Average evaluation score trend per criterion over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Score",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (criterion) (rate(eval_score_sum[10m]) / rate(eval_score_count[10m]))",
          "legendFormat": "{{criterion}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Eval Judge Latency",
      "description": "Histogram of evaluation judge model latency",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" },
        "bucketSize": 100,
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "none",
        "bucketOffset": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (rate(eval_judge_latency_ms_bucket[5m]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 6,
      "title": "Score Heatmap (Criterion vs Time)",
      "description": "Heatmap of evaluation scores by criterion over time",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "scheme", "schemeId": "RdYlGn" },
          "custom": {
            "scaleDistribution": { "type": "linear" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "yHistogram": false },
        "legend": { "show": true },
        "yAxis": {
          "axisLabel": "Criterion",
          "axisPlacement": "left",
          "reverse": false,
          "unit": "short"
        },
        "rowsFrame": { "layout": "auto" },
        "showValue": "never",
        "cellGap": 1,
        "color": {
          "mode": "scheme",
          "scheme": "RdYlGn",
          "fill": "dark-orange",
          "scale": "exponential",
          "exponent": 0.5,
          "steps": 64
        },
        "filterValues": { "le": 1e-9 },
        "calculate": true,
        "calculation": {
          "xBuckets": { "mode": "size", "value": "1h" },
          "yBuckets": { "mode": "count", "value": "10" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (criterion) (rate(eval_score_sum[1h]) / rate(eval_score_count[1h]))",
          "legendFormat": "{{criterion}}"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [],
  "liveNow": false,
  "version": 1
}
