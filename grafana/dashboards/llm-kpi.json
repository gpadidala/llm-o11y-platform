{
  "uid": "llm-kpi",
  "title": "LLM O11y — KPI Scorecard",
  "description": "Key Performance Indicators for LLM operations: availability, performance, cost efficiency, volume, and cross-provider comparison.",
  "tags": ["llm", "observability", "kpi", "scorecard"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "provider",
        "type": "query",
        "label": "Provider",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(llm_requests_total, provider)",
        "query": {
          "query": "label_values(llm_requests_total, provider)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "model",
        "type": "query",
        "label": "Model",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(llm_requests_total{provider=~\"$provider\"}, model)",
        "query": {
          "query": "label_values(llm_requests_total{provider=~\"$provider\"}, model)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "time_window",
        "type": "custom",
        "label": "Time Window",
        "query": "1h,6h,24h,7d",
        "multi": false,
        "includeAll": false,
        "current": { "selected": true, "text": "1h", "value": "1h" },
        "options": [
          { "text": "1h", "value": "1h", "selected": true },
          { "text": "6h", "value": "6h", "selected": false },
          { "text": "24h", "value": "24h", "selected": false },
          { "text": "7d", "value": "7d", "selected": false }
        ]
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Availability",
      "id": 1,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Success Rate",
      "description": "Overall success rate across selected providers and models. Green >99.9%, Yellow >99%, Red <99%.",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "unit": "percent",
          "min": 90,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (1 - (sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status=\"error\"}[$time_window])) / clamp_min(sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$time_window])), 1)))",
          "legendFormat": "Success Rate"
        }
      ]
    },
    {
      "id": 3,
      "title": "Uptime",
      "description": "Service uptime indicator based on whether requests are being processed.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "clamp_max(sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 1) > 0 or vector(0)",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Count",
      "description": "Total number of errors in the selected time window.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status=\"error\"}[$time_window]))",
          "legendFormat": "Errors"
        }
      ]
    },
    {
      "id": 5,
      "title": "Error Rate Trend",
      "description": "Error rate percentage over time.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "hidden", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\", status=\"error\"}[$__rate_interval])) / clamp_min(sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 1)",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "type": "row",
      "title": "Performance",
      "id": 10,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "title": "Mean Latency",
      "description": "Average request latency across all selected providers and models.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 3000 }
            ]
          },
          "unit": "ms",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_request_duration_milliseconds_sum{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])) / clamp_min(sum(rate(llm_request_duration_milliseconds_count{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 0.001)",
          "legendFormat": "Mean Latency"
        }
      ]
    },
    {
      "id": 12,
      "title": "P95 Latency",
      "description": "95th percentile request latency.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "unit": "ms",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(llm_request_duration_milliseconds_bucket{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])))",
          "legendFormat": "P95 Latency"
        }
      ]
    },
    {
      "id": 13,
      "title": "P99 Latency",
      "description": "99th percentile request latency.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "red", "value": 8000 }
            ]
          },
          "unit": "ms",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(llm_request_duration_milliseconds_bucket{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])))",
          "legendFormat": "P99 Latency"
        }
      ]
    },
    {
      "id": 14,
      "title": "TTFT P95",
      "description": "95th percentile Time to First Token.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "ms",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(llm_ttft_milliseconds_bucket{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])))",
          "legendFormat": "TTFT P95"
        }
      ]
    },
    {
      "type": "row",
      "title": "Cost Efficiency",
      "id": 20,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "title": "Cost per 1K Tokens",
      "description": "Average cost per 1,000 tokens processed.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 4,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(sum(rate(llm_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])) / clamp_min(sum(rate(llm_tokens_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 0.001)) * 1000",
          "legendFormat": "Cost / 1K Tokens"
        }
      ]
    },
    {
      "id": 22,
      "title": "Cost per Request",
      "description": "Average cost per LLM request.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 4,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])) / clamp_min(sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])), 0.001)",
          "legendFormat": "Cost / Request"
        }
      ]
    },
    {
      "id": 23,
      "title": "Hourly Cost Rate",
      "description": "Cost accumulation rate projected per hour over time.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "$/hr",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])) * 3600",
          "legendFormat": "Hourly Cost"
        }
      ]
    },
    {
      "id": 24,
      "title": "Daily Cost Projection",
      "description": "Projected daily cost based on current request rate.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 2,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])) * 86400",
          "legendFormat": "Daily Projection"
        }
      ]
    },
    {
      "type": "row",
      "title": "Volume",
      "id": 30,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "title": "Total Requests",
      "description": "Total number of requests in the selected time window.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$time_window]))",
          "legendFormat": "Total Requests"
        }
      ]
    },
    {
      "id": 32,
      "title": "Total Tokens",
      "description": "Total number of tokens processed in the selected time window.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(llm_tokens_total{provider=~\"$provider\", model=~\"$model\"}[$time_window]))",
          "legendFormat": "Total Tokens"
        }
      ]
    },
    {
      "id": 33,
      "title": "Requests per Minute",
      "description": "Request throughput over time measured in requests per minute.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "rpm",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_requests_total{provider=~\"$provider\", model=~\"$model\"}[$__rate_interval])) * 60",
          "legendFormat": "RPM"
        }
      ]
    },
    {
