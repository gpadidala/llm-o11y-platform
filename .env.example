# =============================================================================
# LLM O11y Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Only configure the providers you intend to use. The gateway will skip
# providers whose keys are empty or missing.
# =============================================================================

# =============================================================================
# CORPORATE NETWORK / PROXY SETTINGS
# =============================================================================
# If your corporate network uses an HTTP proxy, configure these.
# The gateway, all LLM SDK calls, and OTel exporters will use them.

# HTTP_PROXY=http://proxy.corp.example.com:8080
# HTTPS_PROXY=http://proxy.corp.example.com:8080
# NO_PROXY=localhost,127.0.0.1,otel-collector,tempo,prometheus,loki,grafana,clickhouse,.corp.example.com

# Custom CA certificate bundle for corporate TLS inspection
# REQUESTS_CA_BUNDLE=/etc/ssl/certs/corp-ca-bundle.crt
# SSL_CERT_FILE=/etc/ssl/certs/corp-ca-bundle.crt
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/corp-ca-bundle.crt

# =============================================================================
# LLM PROVIDER API KEYS
# =============================================================================

# -- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=https://api.openai.com/v1         # Override for corporate proxy
# OPENAI_ORG_ID=org-xxxxx                            # Optional org ID

# -- Azure OpenAI -------------------------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT=gpt-4o                     # Default deployment name

# -- Anthropic ----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# ANTHROPIC_API_BASE=https://api.anthropic.com       # Override for corporate proxy

# -- Google Cloud / Vertex AI -------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VERTEX_PROJECT_ID=your-gcp-project
VERTEX_LOCATION=us-central1

# -- AWS Bedrock --------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
# AWS_SESSION_TOKEN=                                 # For temporary credentials
# AWS_ROLE_ARN=                                      # For role assumption

# -- Cohere -------------------------------------------------------------------
COHERE_API_KEY=your-cohere-key

# =============================================================================
# GATEWAY SETTINGS
# =============================================================================
GATEWAY_PORT=8080
LOG_LEVEL=info
# GATEWAY_WORKERS=4                                  # Uvicorn worker count
# GATEWAY_HOST=0.0.0.0                               # Bind address

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Default admin credentials (change on first login)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin
# SESSION_TTL_HOURS=24                               # Session expiry

# =============================================================================
# OBSERVABILITY
# =============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317  # Auto-set in Docker
# OTEL_SERVICE_NAME=llm-o11y-gateway
