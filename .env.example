# =============================================================================
# LLM Observability Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your provider API keys.
#
#   cp .env.example .env
#
# Only uncomment the providers you intend to use. The gateway will skip
# providers whose keys are empty or missing.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-01

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# -----------------------------------------------------------------------------
# Google Cloud / Vertex AI
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VERTEX_PROJECT_ID=your-gcp-project
VERTEX_LOCATION=us-central1

# -----------------------------------------------------------------------------
# AWS Bedrock
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Cohere
# -----------------------------------------------------------------------------
COHERE_API_KEY=your-cohere-key

# -----------------------------------------------------------------------------
# Gateway Settings
# -----------------------------------------------------------------------------
GATEWAY_PORT=8080
LOG_LEVEL=info
